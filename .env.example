# Copiar a .env y completar (Vite solo expone variables con prefijo VITE_)
# En Vercel: Project Settings → Environment Variables

# Opcional: si no se definen, se usan los valores por defecto embebidos en src/lib/config.js
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL pública de la API (Mercado Pago, callbacks). Por defecto: producción Veltronik
# VITE_API_URL=https://gimnasio-veltronik.vercel.app
