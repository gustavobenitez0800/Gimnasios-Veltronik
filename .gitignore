# ============================================
# VELTRONIK V2 — .gitignore raíz
# ============================================

# Dependencias (nunca se versionan)
node_modules/

# Compilados sueltos de Java fuera de target/
*.class

# Artefactos de build de escritorio (Electron)
release/
release-builds/

# Secretos — NUNCA subir credenciales al repositorio
.env
.env.*
!.env.example

# Scripts operativos ad-hoc con credenciales (regla 8 de docs/ARCHITECTURE.md):
# NUNCA se commitean.
scripts/

# Sistema operativo / editores
.DS_Store
Thumbs.db
*.swp

# Tooling local (preview server, etc.)
.claude/
